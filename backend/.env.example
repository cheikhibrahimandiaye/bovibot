# =============================================================================
# BOVIBOT - Variables d'environnement
# Copier ce fichier en .env et renseigner les valeurs
# =============================================================================

# --- Base de données MySQL ---
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=bovibot

# --- Ollama (LLM local) ---
# Installer Ollama : https://ollama.com
# Puis : ollama pull mistral
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=mistral

# --- Application ---
API_PORT=8002
